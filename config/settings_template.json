        "session_warning_minutes": 25,
        "max_login_attempts": 5,
        "lockout_duration_minutes": 15,
        "log_level": "INFO",
        "log_max_bytes": 10485760,
        "log_backup_count": 5,
        "auto_save_interval_seconds": 30
